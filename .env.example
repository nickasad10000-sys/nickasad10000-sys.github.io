# TITAN PRO · V8 — API keys (build-time injected into client bundle).
# IMPORTANT: Anything starting with VITE_ is exposed in the public JS bundle.
# The user has accepted this trade-off for a private team site.

# OpenRouter (https://openrouter.ai) — gives access to Claude, GPT, Gemini etc.
VITE_OPENROUTER_API_KEY=sk-or-v1-REPLACE-ME

# Google AI Studio (https://aistudio.google.com) — Gemini direct.
VITE_GOOGLE_STUDIO_API_KEY=REPLACE-ME

# Default provider + model used when the user hasn't picked one in Settings.
# Models that work on the free tier of OpenRouter:
#   - anthropic/claude-3-haiku
#   - openai/gpt-4o-mini
#   - google/gemini-2.0-flash-exp:free
VITE_LLM_PROVIDER=openrouter
VITE_LLM_MODEL=anthropic/claude-3-haiku
