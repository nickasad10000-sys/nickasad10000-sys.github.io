{
  "name": "titan-pro",
  "version": "8.0.0",
  "type": "module",
  "description": "TITAN PRO — Social Media Analytics, Spartan Edition",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "scrape:public": "python scripts/scrape/scraper_public.py",
