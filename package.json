    "scrape": "npm run scrape:public && npm run scrape:cookies && npm run scrape:aggregate && npm run scrape:llm && npm run scrape:fmt",
    "scrape:build": "npm run scrape && npm run build"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
